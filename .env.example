# 复制为 .env并填入真实值（.env 已在 .gitignore 中，不会被提交）
#
# === Amadeus（免费，推荐）===
# 1. 打开 https://developers.amadeus.com 注册账号
# 2. My Self-Service Workspace → Create new app → 记下 API Key与 API Secret
# 3. 把 Key 填到下面 CLIENT_ID，Secret 填到 CLIENT_SECRET
# 4. 项目根目录执行:
#      pip install -e .
#      cp config/config.amadeus.example.yaml config/config.yaml
#      python -m flight_deal_agent verify-amadeus
#      python -m flight_deal_agent run-once
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
